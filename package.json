{
  "name": "api-requests-deduper",
  "version": "0.1.0",
  "description": "Chrome DevTools extension that shows unique API requests with a call counter (deduplication of polling/duplicate XHR/fetch requests).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/chrome": "0.1.40",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "sass": "1.99.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-static-copy": "4.1.0"
  }
}
